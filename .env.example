# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, so your real secrets never get committed.

# Notion internal integration token (Settings -> Connections -> Develop or manage integrations)
NOTION_TOKEN=

# Anthropic API key (console.anthropic.com) - needed starting Milestone 5
ANTHROPIC_API_KEY=

# Skill launch URLs (Milestone 7) - leave blank until each skill has a real
# URL; the Skills panel just won't open a new tab until these are filled in.
NEXT_PUBLIC_XO_WOW_STUDIO_URL=
NEXT_PUBLIC_SUBMISSION_REVIEW_URL=

# Clerk auth (dashboard.clerk.com) - needed starting Milestone 10
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Points Clerk at our own sign-in/sign-up pages instead of its hosted Account Portal
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
