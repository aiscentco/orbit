# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, so your real secrets never get committed.

# Notion internal integration token (Settings -> Connections -> Develop or manage integrations)
NOTION_TOKEN=

# Anthropic API key (console.anthropic.com) - needed starting Milestone 5
ANTHROPIC_API_KEY=

# Skill launch URLs (Milestone 7) - leave blank until each skill has a real
# URL; the Skills panel just won't open a new tab until these are filled in.
NEXT_PUBLIC_XO_WOW_STUDIO_URL=
NEXT_PUBLIC_SUBMISSION_REVIEW_URL=

# Clerk auth (dashboard.clerk.com) - needed starting Milestone 10
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Points Clerk at our own sign-in/sign-up pages instead of its hosted Account Portal
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Resend (resend.com) - needed starting Milestone 13, for gate-alert emails
RESEND_API_KEY=
# "Name <email>" - onboarding@resend.dev works without a verified domain for
# testing; switch to a verified sending address before emailing real clients.
ALERTS_FROM_EMAIL=Orbit <onboarding@resend.dev>
# Random secret that must match the Authorization: Bearer header on requests
# to /api/cron/gate-alerts - stops randoms from triggering client emails.
CRON_SECRET=
# Base URL used to build links inside alert emails (e.g. https://orbit.aiscent.co in production)
APP_URL=http://localhost:3000
